<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_swipe"
        android:title="@string/settings_category_swipe"
        android:defaultValue="true">

        <rikka.preference.SimpleMenuPreference
            android:key="swipe_right_action"
            android:title="@string/settings_swipe_right"
            android:entries="@array/swipe_actions"
            android:entryValues="@array/swipe_actions_values"
            android:defaultValue="open_app"
            android:summary="%s"
            android:icon="@drawable/ic_swipe_24" />

        <rikka.preference.SimpleMenuPreference
            android:key="swipe_left_action"
            android:title="@string/settings_swipe_left"
            android:entries="@array/swipe_actions"
            android:entryValues="@array/swipe_actions_values"
            android:defaultValue="app_info"
            android:summary="%s"
            android:icon="@drawable/ic_swipe_24" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_long_press"
        android:title="@string/settings_category_long_press"
        android:defaultValue="true">

        <Preference
            android:key="lp_category_info"
            style="?preferenceInformationStyle"
            android:summary="@string/settings_lp_category_summary" />

        <SwitchPreferenceCompat
            android:key="lp_open_app"
            android:title="@string/settings_lp_open_app"
            android:defaultValue="true"
            android:icon="@drawable/ic_outline_play_arrow_24" />

        <SwitchPreferenceCompat
            android:key="lp_app_info"
            android:title="@string/settings_lp_app_info"
            android:defaultValue="true"
            android:icon="@drawable/ic_outline_info_24" />

        <SwitchPreferenceCompat
            android:key="lp_toggle_permission"
            android:title="@string/settings_lp_toggle_permission"
            android:defaultValue="true"
            android:icon="@drawable/ic_shield_24" />

        <SwitchPreferenceCompat
            android:key="lp_hide_from_list"
            android:title="@string/settings_lp_hide_from_list"
            android:defaultValue="true"
            android:icon="@drawable/ic_visibility_24" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

    <af.shizuku.manager.settings.CollapsiblePreferenceCategory
        android:key="category_verified_install"
        android:title="Verified Installation (Third-Party APKs)"
        android:defaultValue="true">

        <SwitchPreferenceCompat
            android:key="verify_apk_local"
            android:title="Local Signature Matching"
            android:summary="Verify updates mathematically match the installed app's signature. Fast and 100% offline."
            android:defaultValue="true"
            android:icon="@drawable/ic_shield_24" />

        <SwitchPreferenceCompat
            android:key="verify_apk_fdroid"
            android:title="F-Droid / IzzyOnDroid Offline Index"
            android:summary="Verify APK hashes locally against trusted open-source metadata. Enabled by default for privacy."
            android:defaultValue="true"
            android:icon="@drawable/ic_folder_24" />

        <SwitchPreferenceCompat
            android:key="verify_apk_virustotal"
            android:title="VirusTotal Integration"
            android:summary="Scan third-party APK hashes against the VirusTotal API before installation. Requires network."
            android:defaultValue="false"
            android:icon="@drawable/ic_system_update" />
            
        <SwitchPreferenceCompat
            android:key="verify_apk_pithus"
            android:title="Pithus Threat Intel"
            android:summary="Check hashes against Pithus (open-source MobSF aggregator) to detect malware traits."
            android:defaultValue="false"
            android:icon="@drawable/ic_admin_panel_settings_24" />

    </af.shizuku.manager.settings.CollapsiblePreferenceCategory>

</PreferenceScreen>
